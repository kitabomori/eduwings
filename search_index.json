---
layout: none
permalink: /search_index.json
---
[
{% assign all_items = "" | split: "" %}
{% assign all_items = all_items | concat: site.blogs %}
{% assign all_items = all_items | concat: site.opeds %}
{% assign all_items = all_items | concat: site.letters %}
{% assign all_items = all_items | concat: site.book_reviews %}
{% assign all_items = all_items | concat: site.reflections %}
{% assign all_items = all_items | concat: site.calls %}
{% assign sorted = all_items | sort: "date" | reverse %}
{% for item in sorted %}
  {
    "title_en": {{ item.title_en | jsonify }},
    "title_ur": {{ item.title_ur | jsonify }},
    "url_en": "{{ site.baseurl }}/en{{ item.url }}",
    "url_ur": "{{ site.baseurl }}/ur{{ item.url }}",
    "date": "{{ item.date | date: '%Y-%m-%d' }}",
    "type_en": "{% if site.blogs contains item %}Blog{% elsif site.opeds contains item %}Op-Ed{% elsif site.letters contains item %}Letter{% elsif site.book_reviews contains item %}Book Review{% elsif site.reflections contains item %}Reflection{% else %}Call{% endif %}",
    "type_ur": "{% if site.blogs contains item %}بلاگ{% elsif site.opeds contains item %}اوپیڈ{% elsif site.letters contains item %}خط{% elsif site.book_reviews contains item %}کتابی جائزہ{% elsif site.reflections contains item %}عکاسی{% else %}دعوت{% endif %}"
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
