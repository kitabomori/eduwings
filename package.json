{
  "name": "eduwings",
  "version": "1.0.0",
  "description": "Kitabomori – bilingual educational publishing website",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/main.css -o ./_site/assets/css/main.css --minify",
    "build:css:dev": "tailwindcss -i ./assets/css/main.css -o ./assets/css/compiled.css",
    "watch:css": "tailwindcss -i ./assets/css/main.css -o ./assets/css/compiled.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4"
  }
}
